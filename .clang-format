---
Language: Cpp
BasedOnStyle: LLVM
IndentWidth: 2
TabWidth: 2
UseTab: Never

# Strict Allman Braces
# Braces are always placed on their own lines for virtually everything.
BreakBeforeBraces: Custom
BraceWrapping:
  AfterCaseLabel: false
  AfterClass: true
  AfterControlStatement: Always
  AfterEnum: true
  AfterFunction: true
  AfterNamespace: true
  AfterStruct: true
  AfterUnion: true
  AfterExternBlock: true
  BeforeCatch: true
  BeforeElse: true
  BeforeWhile: false
  IndentBraces: false

# Column Alignment
# Type names, variable names, assignments, and macros are often column-aligned
# for readability when looking at data structures.
AlignConsecutiveDeclarations:
  Enabled: true
AlignConsecutiveAssignments:
  Enabled: true
AlignConsecutiveMacros:
  Enabled: true

# Pointers bind to the variable name (e.g., String8 *name)
PointerAlignment: Right

SpaceBeforeParens: ControlStatements
SpaceAfterCStyleCast: false

# Block Expansion
# Blocks, cases, ifs, and loops are never compressed onto a single line.
AllowShortBlocksOnASingleLine: Empty
AllowShortCaseLabelsOnASingleLine: false
AllowShortFunctionsOnASingleLine: Empty
AllowShortIfStatementsOnASingleLine: Never
AllowShortLoopsOnASingleLine: false

# Manual Include Ordering
# Because raddebugger uses a unity build and strict dependency hierarchies,
# auto-sorting includes will easily break the build.
SortIncludes:
  Enabled: false
IncludeBlocks: Preserve

# Indent case labels inside switches rather than keeping them flush with 'switch'
IndentCaseLabels: true
...
