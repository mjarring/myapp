FROM debian:bookworm-slim

# Install aarch64 cross-compiler and host wayland tools
RUN apt-get update && apt-get install -y --no-install-recommends \
  gcc-aarch64-linux-gnu \
  g++-aarch64-linux-gnu \
  libwayland-bin \
  wayland-protocols \
  && dpkg --add-architecture arm64 \
  && apt-get update \
  && apt-get install -y --no-install-recommends \
  pkg-config:arm64 \
  libwayland-dev:arm64 \
  libxkbcommon-dev:arm64 \
  python3 \
  && rm -rf /var/lib/apt/lists/*

COPY ./compile-common.sh /usr/local/bin/compile-common.sh
RUN chmod +x /usr/local/bin/compile-common.sh
COPY ./compile-aarch64.sh /usr/local/bin/compile-aarch64.sh
RUN chmod +x /usr/local/bin/compile-aarch64.sh

COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/
